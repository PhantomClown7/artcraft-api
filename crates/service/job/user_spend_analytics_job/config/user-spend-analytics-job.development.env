SERVER_ENVIRONMENT=development
RUST_LOG=info

# Cycle cadence + throttling
SLEEP_BETWEEN_CYCLES_SECONDS=86400
QUERY_DELAY_MILLIS=50
ERROR_RECOVERY_SECONDS=30

# Daily-spends backfill window (pick ONE; omit both = all-time, with a warning)
BACKFILL_DAYS=3
# BACKFILL_START_DATE=2026-02-01

# Summaries
SUMMARY_USER_PAGE_SIZE=500

# Reengagement score tunables
REENGAGEMENT_VALUE_CAP_DOLLARS=1000
REENGAGEMENT_ACTIVE_THRESHOLD_DAYS=14
REENGAGEMENT_DECAY_DAYS=350

# Paging (off in dev)
ENABLE_PAGING=false
