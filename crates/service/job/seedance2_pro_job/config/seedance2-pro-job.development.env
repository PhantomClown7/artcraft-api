# default .env configurations (these can be overridden with k8s)

# Development
SERVER_ENVIRONMENT='development'

# Paging
ENABLE_PAGING=true

# Doesn't make sense for jobs:
# ENABLE_PAGING_FOR_500S=true

# We don't need to look back that far in development
MAX_JOB_AGE_THRESHOLD_HOURS=5

# Don't collide with storyteller-web in development
HTTP_BIND_ADDRESS=0.0.0.0:11223

